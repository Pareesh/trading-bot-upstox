PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Create an app at https://account.upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
# Must match the redirect URI registered on the Upstox developer portal
UPSTOX_REDIRECT_URI=http://localhost:4000/api/auth/upstox/callback

# If your app is registered for algo trading, set the name exactly as in Upstox
# UPSTOX_ALGO_NAME=

# Random secret at least 32 characters — encrypts the stored OAuth access token on disk
TOKEN_ENCRYPTION_KEY=
LIVE_TRADING_ENABLED="false"